generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  TASK
  STORY
  BUG
}

enum ProjectRole {
  ADMIN
  MEMBER
}

model User {
  id              String          @id
  email           String          @unique
  name            String?
  avatarUrl       String?
  createdTasks    Task[]          @relation("TaskCreator")
  assignedTasks   Task[]          @relation("TaskAssignee")
  memberProjects  ProjectMember[]
  createdProjects Project[]       @relation("ProjectCreator")
  lists           BoardList[]     @relation("ListCreator")
  createdAt       DateTime        @default(now())
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  userId      String       // Creator
  creator     User         @relation("TaskCreator", fields: [userId], references: [id])
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  listId      String
  list        BoardList    @relation(fields: [listId], references: [id], onDelete: Cascade)
  sprintId    String?
  sprint      Sprint?      @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  position    Int          @default(0)
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  type        TaskType     @default(TASK)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime     @default(now())

  @@index([userId, listId])
  @@index([listId, position])
  @@index([sprintId])
}

model Project {
  id        String          @id @default(uuid())
  name      String
  color     String
  userId    String          // Creator
  creator   User            @relation("ProjectCreator", fields: [userId], references: [id])
  members   ProjectMember[]
  createdAt DateTime        @default(now())
  lists     BoardList[]
  sprints   Sprint[]

  @@index([userId])
}

model Sprint {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  position  Int      @default(0)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]
  createdAt DateTime @default(now())

  @@index([projectId, position])
}

model ProjectMember {
  id        String      @id @default(uuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ProjectRole @default(MEMBER)
  createdAt DateTime    @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model BoardList {
  id        String   @id @default(uuid())
  name      String
  color     String
  userId    String
  creator   User     @relation("ListCreator", fields: [userId], references: [id])
  projectId String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([projectId, position])
  @@index([userId])
}
